{
  "name": "moon-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:moon-frontend": "node dist/moon-frontend/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "dependencies": {
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.4",
    "@ant-design/icons": "^6.1.0",
    "@ant-design/icons-angular": "^21.0.0",
    "@apollo/client": "^4.0.1",
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "apollo-angular": "^13.0.0",
    "echarts": "^6.0.0",
    "express": "^5.1.0",
    "graphql": "^16",
    "ng-zorro-antd": "^21.1.1",
    "ngx-echarts": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^27.1.0",
    "less": "^4.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}